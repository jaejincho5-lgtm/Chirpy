# LLM
# The agent uses AI SDK v5 with plain "provider/model" strings routed through
# the Vercel AI Gateway. Set this for a live demo response on Vercel.
AI_GATEWAY_API_KEY=
# Optional model override (default: anthropic/claude-opus-4-8). Useful for
# running evals on a cheaper gateway tier, e.g. anthropic/claude-haiku-4-5.
AGENT_MODEL=

# AWS AgentCore Observability
# If the agent loop is deployed as AgentCore Harness, CloudWatch telemetry is
# emitted by AWS automatically after one-time Transaction Search setup.
# Set this locally to emit structured trace/session metadata from /api/agent
# and npm run eval logs while we are still running the loop in this Next app.
AGENTCORE_OBSERVABILITY_ENABLED=
AGENTCORE_SERVICE_NAME=kfc-conversational-ordering-agent
AGENTCORE_HARNESS_NAME=
AGENTCORE_AWS_REGION=

# Demo controls (out-of-stock toggle endpoint + UI button). Enabled
# automatically outside production; set to 1 to enable on a deployed demo.
DEMO_CONTROLS=

# Supabase
# The scaffold runs with in-memory mocks. Set these when seeding/persisting menu
# and order state in the shared Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Channel mode. MESSENGER_TOKEN (Page access token) enables the
# real send-reply APIs; without them the webhook still runs the agent and
# returns the reply in the response body (simulation mode).
MESSENGER_TOKEN=
MESSENGER_VERIFY_TOKEN=
# Secrets used to verify inbound webhook signatures. When unset, signature
# verification is skipped (stub mode). Set them to enforce verification.
MESSENGER_APP_SECRET=

# OTP: the code is server-generated and never returned by default. Set to 1 to
# surface a dev code in the tool payload/UI for local scaffold testing only.
OTP_EXPOSE_DEV_CODE=

# Zero-re-entry checkout: risk-based OTP skip for trusted repeat customers. Set
# to 1 (default ON for the demo) to let a returning customer with a saved
# contact skip the OTP on a small order (<200k) going to their saved address.
# Unset ⇒ full OTP always (identical to pre-feature behavior). The skip is
# recomputed server-side in place_order, so it can never be forged by the client.
TRUSTED_SKIP_OTP=1

# Chirpy chat→voice handoff. Public base URL used to build the /voice magic
# link (falls back to VERCEL_URL then http://localhost:3000). VOICE_LINK_SECRET
# signs the short-lived channelEcho that authorizes a receipt back to Messenger;
# set a random value in production (defaults to a dev secret locally).
NEXT_PUBLIC_APP_URL=
VOICE_LINK_SECRET=

# /voice TTS. ElevenLabs Flash (eleven_flash_v2_5) gives the chicken a real
# Vietnamese voice with amplitude lip-sync + a server audio cache. Unset ⇒ the
# /api/tts route returns 503 and the client uses the browser voice (demo never
# dies on a missing key or quota). ELEVENLABS_VOICE_ID overrides the default
# multilingual voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Later OMS integration. Leave empty for the mock OMS in lib/oms.ts.
OMS_URL=
